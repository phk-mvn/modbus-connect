{
  "name": "modbus-connect",
  "version": "4.0.3",
  "description": "Modbus RTU/TCP over Web Serial",
  "main": "./dist/client.js",
  "module": "./dist/client.js",
  "type": "commonjs",
  "types": "./dist/types/modbus-types.d.ts",
  "exports": {
    "./client": {
      "types": "./dist/client.d.ts",
      "require": "./dist/client.js",
      "import": "./dist/client.js"
    },
    "./transport": {
      "types": "./dist/transport/transport-controller.d.ts",
      "require": "./dist/transport/transport-controller.js",
      "import": "./dist/transport/transport-controller.js"
    },
    "./types": {
      "types": "./dist/types/modbus-types.d.ts",
      "require": "./dist/types/modbus-types.js",
      "import": "./dist/types/modbus-types.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "tsc --watch",
    "test": "node test-crc.js",
    "lint": "eslint . --fix",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/phk-mvn/modbus-connect.git"
  },
  "bugs": {
    "url": "https://github.com/phk-mvn/modbus-connect/issues"
  },
  "homepage": "https://github.com/phk-mvn/modbus-connect#readme",
  "keywords": [
    "modbus",
    "modbus-node",
    "modbus-web",
    "modbus-rtu",
    "modbus-tcp",
    "modbus-stream",
    "modbus-serial",
    "modbus-web-serial",
    "modbus-tcp-serial",
    "modbus-web-tcp-serial",
    "modbus-emulator",
    "modbus-polling-manager",
    "modbus-logger",
    "modbus-utils",
    "modbus-crc",
    "modbus-diagnostics",
    "modbus-constants",
    "modbus-errors",
    "modbus-packet-builder",
    "modbus-transport",
    "web-tcp",
    "web-serial",
    "web-serial-tcp",
    "web-serial-rtu",
    "web-serial-udp",
    "web-serial-rtu-tcp",
    "web-serial-rtu-udp",
    "web-serial-rtu-tcp-udp",
    "jsmodbus",
    "tsmodbus",
    "serialport",
    "tcp",
    "udp",
    "crc",
    "rtu",
    "com",
    "serial",
    "port",
    "arduino",
    "client",
    "server",
    "automation",
    "stream",
    "node-crc",
    "node-crc16",
    "typescript"
  ],
  "author": "Danila Dukin",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@types/serialport": "^10.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "serialport": "^13.0.0"
  }
}
